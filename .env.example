# API Host & Port Settings
HOST=localhost,127.0.0.1
PORT=8000

# Database Settings
# For local SQLite development: sqlite+aiosqlite:///books.db
# For production PostgreSQL: postgresql+asyncpg://postgres:postgres@db:5432/books_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/books_db

# Security & JWT Token Settings (Use secure keys in production)
ACCESS_SECRET_KEY=super_secure_access_secret_key_change_me_in_production
REFRESH_SECRET_KEY=super_secure_refresh_secret_key_change_me_in_production
